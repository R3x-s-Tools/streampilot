# Twitch app credentials from https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_REDIRECT_URI=http://localhost:17563/callback
TWITCH_CHANNEL=dad_r3x
# keyring uses the OS credential store; file is an explicit development fallback
STREAMPILOT_SECRET_STORE=keyring

# OBS on Windows PC
OBS_HOST=192.168.1.25
OBS_PORT=4455
OBS_PASSWORD=

# AI options: off, openai
AI_PROVIDER=off
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Timing
OBS_POLL_SECONDS=3
TWITCH_ANALYTICS_SECONDS=60
AI_REFRESH_SECONDS=45
# Discord reporting
DISCORD_REPORT_WEBHOOK_URL=
REPORT_TO_DISCORD=false
